{
  "expo": {
    "name": "KeyGo",
    "slug": "keygo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "keygo",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.keygo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E4FA3"
      },
      "package": "com.keygo.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
